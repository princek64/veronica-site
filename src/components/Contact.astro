---
import { content } from '../content.js';
---
<section class="connect" id="connect">
  <div class="container">
    <div class="connect__card" data-animate="fade-up">
      <p class="connect__eyebrow">{content.connectEyebrow}</p>
      <h2 class="connect__heading">{content.connectHeading}</h2>
      <p class="connect__sub">{content.connectSubtext}</p>
      <div class="connect__links">
        <a href={`mailto:${content.contactEmail}`} class="connect__btn connect__btn--solid">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <rect x="2" y="4" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.4"/>
            <path d="M2 6l7 5 7-5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          {content.contactEmail}
        </a>
        <a href={content.instagramUrl} target="_blank" rel="noopener" class="connect__btn connect__btn--outline">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <rect x="2" y="2" width="14" height="14" rx="4" stroke="currentColor" stroke-width="1.4"/>
            <circle cx="9" cy="9" r="3.5" stroke="currentColor" stroke-width="1.4"/>
            <circle cx="13" cy="5" r="1" fill="currentColor"/>
          </svg>
          {content.instagramHandle}
        </a>
      </div>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__left">
      <a href="#" class="footer__logo">{content.practiceName}</a>
      <p class="footer__tagline">{content.tagline}</p>
    </div>
    <div class="footer__center">
      <nav class="footer__nav">
        {content.navLinks.map(link => (
          <a href={link.href}>{link.label}</a>
        ))}
      </nav>
    </div>
    <div class="footer__right">
      <p class="footer__location">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="display:inline;vertical-align:-2px;margin-right:4px">
          <path d="M7 1C4.79 1 3 2.79 3 5c0 3.25 4 8 4 8s4-4.75 4-8c0-2.21-1.79-4-4-4z" stroke="currentColor" stroke-width="1.2"/>
          <circle cx="7" cy="5" r="1.5" stroke="currentColor" stroke-width="1.2"/>
        </svg>
        {content.footerLocation}
      </p>
    </div>
  </div>
  <div class="container">
    <div class="footer__bottom">
      <p>&copy; {content.footerCopyright}</p>
    </div>
  </div>
</footer>

<style>
.connect {
  padding: 80px 0 0;
}
.connect__card {
  background: var(--teal);
  border-radius: 28px;
  padding: 80px 48px 100px;
  text-align: center;
  color: white;
}
.connect__eyebrow {
  font-family: var(--font-body);
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.5);
  margin-bottom: 20px;
  font-weight: 400;
}
.connect__heading {
  font-family: var(--font-display);
  font-size: clamp(34px, 5vw, 56px);
  font-weight: 400;
  color: white;
  margin-bottom: 24px;
  letter-spacing: -0.01em;
}
.connect__sub {
  font-size: 15.5px;
  font-weight: 300;
  color: rgba(255,255,255,0.75);
  max-width: 500px;
  margin: 0 auto 48px;
  line-height: 1.75;
}
.connect__links {
  display: flex;
  justify-content: center;
  gap: 14px;
  flex-wrap: wrap;
}
.connect__btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 15px 28px;
  border-radius: var(--radius-pill);
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 400;
  letter-spacing: 0.02em;
  transition: transform 0.25s, background 0.25s, box-shadow 0.35s;
}
.connect__btn:hover { transform: translateY(-2px); }
.connect__btn--solid {
  background: white;
  color: var(--teal-dark);
}
.connect__btn--solid:hover {
  background: var(--linen);
  box-shadow: 0 8px 24px rgba(0,0,0,0.12);
}
.connect__btn--outline {
  background: transparent;
  color: white;
  border: 1.5px solid rgba(255,255,255,0.35);
}
.connect__btn--outline:hover {
  background: rgba(255,255,255,0.08);
  border-color: rgba(255,255,255,0.6);
}

/* ── Footer ── */
.footer {
  background: var(--linen);
  padding-top: 64px;
  margin-top: 0;
}
.footer__inner {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 40px;
  padding-bottom: 32px;
}
.footer__left {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.footer__logo {
  font-family: var(--font-display);
  font-size: 24px;
  font-weight: 400;
  font-style: italic;
  color: var(--teal-dark);
  letter-spacing: 0.02em;
  transition: color 0.2s;
}
.footer__logo:hover { color: var(--teal); }
.footer__tagline {
  font-size: 12px;
  color: var(--text-body);
  opacity: 0.6;
  font-weight: 300;
  letter-spacing: 0.02em;
}
.footer__center {
  text-align: center;
}
.footer__nav {
  display: flex;
  gap: 32px;
}
.footer__nav a {
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: 400;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-body);
  opacity: 0.7;
  transition: opacity 0.2s, color 0.2s;
}
.footer__nav a:hover {
  color: var(--teal);
  opacity: 1;
}
.footer__right {
  text-align: right;
}
.footer__location {
  font-size: 13px;
  color: var(--text-body);
  opacity: 0.6;
  font-weight: 300;
}
.footer__bottom {
  border-top: 1px solid rgba(217, 205, 184, 0.5);
  padding: 20px 0 28px;
  text-align: center;
}
.footer__bottom p {
  font-size: 11px;
  color: var(--text-body);
  opacity: 0.4;
  letter-spacing: 0.04em;
}

@media (max-width: 768px) {
  .connect__card { padding: 60px 24px 80px; border-radius: 20px; }
  .footer__inner {
    grid-template-columns: 1fr;
    text-align: center;
    gap: 24px;
  }
  .footer__left { align-items: center; }
  .footer__right { text-align: center; }
  .footer__nav { justify-content: center; }
}
</style>
