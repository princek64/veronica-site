---
import { content } from '../content.js';

// Icon SVGs keyed by service id — kept in the component since these are design elements, not content
const icons = {
  'one-on-one': `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="10" r="5" stroke="currentColor" stroke-width="1.5"/><path d="M5 24c0-4.97 4.03-9 9-9s9 4.03 9 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  'art-therapy': `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="10" stroke="currentColor" stroke-width="1.5"/><circle cx="10" cy="11" r="2" fill="currentColor" opacity="0.5"/><circle cx="18" cy="11" r="1.5" fill="currentColor" opacity="0.4"/><circle cx="14" cy="17" r="2.5" fill="currentColor" opacity="0.3"/></svg>`,
  'dream-work': `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M20 8a8 8 0 1 1-11.3 11.3A6 6 0 0 0 20 8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M16 5l.5-2M19 7l1.5-1.5M21 10l2-.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  'womens-circles': `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="10" cy="10" r="3.5" stroke="currentColor" stroke-width="1.5"/><circle cx="18" cy="10" r="3.5" stroke="currentColor" stroke-width="1.5"/><path d="M4 22c0-3.31 2.69-6 6-6h8c3.31 0 6 2.69 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
};
---

<section class="offerings" id="offerings">
  <div class="container">
    <div class="offerings__header" data-animate="fade-up">
      <p class="offerings__eyebrow">{content.offeringsEyebrow}</p>
      <h2 class="offerings__title">{content.offeringsTitle}</h2>
      <p class="offerings__sub">{content.offeringsSubtext}</p>
    </div>
    <div class="offerings__grid">
      {content.services.map((s, i) => (
        <article
          class={`service-card service-card--${s.id}`}
          data-animate="fade-up"
          data-delay={String(i * 100)}
        >
          <div class="service-card__top">
            <div class="service-card__icon" set:html={icons[s.id]} />
            <span class="service-card__number">{String(i + 1).padStart(2, '0')}</span>
          </div>
          <h3 class="service-card__title">{s.title}</h3>
          <div class="service-card__divider"></div>
          <p class="service-card__body">{s.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.offerings {
  padding: 120px 0;
}
.offerings__header {
  text-align: center;
  max-width: 560px;
  margin: 0 auto 72px;
}
.offerings__eyebrow {
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--teal-muted);
  margin-bottom: 16px;
  font-weight: 400;
}
.offerings__title {
  font-size: clamp(34px, 4vw, 52px);
  font-weight: 400;
  margin-bottom: 20px;
  letter-spacing: -0.01em;
}
.offerings__sub {
  font-size: 16px;
  font-weight: 300;
  color: var(--text-body);
  line-height: 1.75;
}

/* ── Masonry-style Grid ── */
.offerings__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: auto auto;
  gap: 16px;
}

/* Card 1 (1-on-1): top-left, tall */
.service-card--one-on-one {
  grid-row: 1 / 3;
  background: var(--teal);
  color: white;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  min-height: 480px;
}
.service-card--one-on-one .service-card__top { order: -1; }
.service-card--one-on-one .service-card__number { color: rgba(255,255,255,0.3); }
.service-card--one-on-one .service-card__icon {
  background: rgba(255,255,255,0.12);
  color: white;
}
.service-card--one-on-one .service-card__title { color: white; }
.service-card--one-on-one .service-card__divider { background: rgba(255,255,255,0.2); }
.service-card--one-on-one .service-card__body { color: rgba(255,255,255,0.75); }

/* Card 2 (Art Therapy): top-right */
.service-card--art-therapy {
  background: var(--blush);
}

/* Card 3 (Dream Workshops): bottom-right */
.service-card--dream-work {
  background: var(--sage-card);
}

/* Card 4 (Women's Circles): full width bottom */
.service-card--womens-circles {
  grid-column: 1 / -1;
  background: var(--linen-dark);
  display: grid;
  grid-template-columns: auto 1fr;
  grid-template-rows: auto auto auto;
  column-gap: 32px;
}
.service-card--womens-circles .service-card__top {
  grid-row: 1;
  grid-column: 1;
}
.service-card--womens-circles .service-card__title {
  grid-column: 2;
  grid-row: 1;
  align-self: end;
}
.service-card--womens-circles .service-card__divider {
  grid-column: 2;
  grid-row: 2;
}
.service-card--womens-circles .service-card__body {
  grid-column: 2;
  grid-row: 3;
  max-width: 520px;
}

/* ── Card base styles ── */
.service-card {
  border-radius: 20px;
  padding: 32px 28px;
  position: relative;
  overflow: hidden;
  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
              box-shadow 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  cursor: default;
}
.service-card::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 20px;
  border: 1px solid rgba(61, 107, 99, 0.04);
  pointer-events: none;
}
.service-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 16px 40px rgba(61, 107, 99, 0.08);
}

.service-card__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24px;
}

.service-card__number {
  font-family: var(--font-display);
  font-size: 14px;
  font-weight: 300;
  color: var(--sand);
  letter-spacing: 0.05em;
  font-style: italic;
}

.service-card__icon {
  width: 48px;
  height: 48px;
  border-radius: 14px;
  background: rgba(255,255,255,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--teal);
  transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
              background 0.3s;
  flex-shrink: 0;
}
.service-card:hover .service-card__icon {
  transform: scale(1.08);
  background: rgba(255,255,255,0.9);
}

.service-card__title {
  font-size: 24px;
  font-weight: 400;
  margin-bottom: 14px;
  letter-spacing: -0.01em;
}

.service-card__divider {
  width: 28px;
  height: 1.5px;
  background: var(--sand);
  margin-bottom: 14px;
  transition: width 0.35s ease;
}
.service-card:hover .service-card__divider {
  width: 48px;
}

.service-card__body {
  font-size: 14px;
  font-weight: 300;
  line-height: 1.75;
  color: var(--text-body);
}

@media (max-width: 768px) {
  .offerings__grid {
    grid-template-columns: 1fr;
  }
  .service-card--one-on-one {
    grid-row: auto;
    min-height: auto;
  }
  .service-card--womens-circles {
    grid-column: 1;
    grid-template-columns: 1fr;
  }
  .service-card--womens-circles .service-card__top,
  .service-card--womens-circles .service-card__title,
  .service-card--womens-circles .service-card__divider,
  .service-card--womens-circles .service-card__body {
    grid-column: 1;
    grid-row: auto;
  }
}
</style>
